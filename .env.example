# Frontend (Vite) — safe to expose; RLS protects the data.
# Local: get these from `supabase status`. Cloud: Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Midtrans client key (Snap.js — client-side only, never the server key)
VITE_MIDTRANS_CLIENT_KEY=
VITE_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# App environment tag (development | staging | production)
VITE_APP_ENV=development

# ---------------------------------------------------------------------------
# Server-side only — DO NOT prefix with VITE_ and DO NOT commit real values.
# Set for Edge Functions via: supabase secrets set KEY=value
# ---------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false
