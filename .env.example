# Frontend (Vite) — safe to expose; RLS protects the data.
# Local: get these from `supabase status`. Cloud: Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---------------------------------------------------------------------------
# Server-side only — DO NOT prefix with VITE_ and DO NOT commit real values.
# Set for Edge Functions via: supabase secrets set KEY=value
# ---------------------------------------------------------------------------
# SUPABASE_SERVICE_ROLE_KEY=
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false
